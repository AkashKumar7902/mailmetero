# pnpm strictness that mechanically enforces the §6 DAG (CONTRACTS_CORE §7).
# Non-flat node_modules => a package can import ONLY what its package.json declares;
# a phantom (hoist-leaked) cross-package import fails at build time.
engine-strict=true
save-workspace-protocol=rolling
# no hoisting of workspace deps into a shared flat tree
node-linker=isolated
auto-install-peers=false
