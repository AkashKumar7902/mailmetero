# mailmetero — environment contract (documented, non-secret template).
# Real values live in Render env group `mailmetero-shared` and local .env (gitignored).
# The typed loader in @mailmetero/config/src/env.ts is the SINGLE authority: it
# validates every var below at boot and refuses to start on any error (fail-fast).

# ── runtime role ────────────────────────────────────────────────────────────
NODE_ENV=development                 # development | production | test
SERVICE_ROLE=web                     # web | worker | cron  (selects pooled vs unpooled defaults)
PORT=8080                            # web only; Render injects this in prod
LOG_LEVEL=info                       # fatal|error|warn|info|debug|trace

# ── database (Neon) ─────────────────────────────────────────────────────────
# web uses the POOLED (-pooler) host; worker/cron/migrations use the DIRECT host (D20).
DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.us-west-2.aws.neon.tech/neondb?sslmode=require&channel_binding=require
DATABASE_URL_UNPOOLED=postgresql://user:pass@ep-xxx.us-west-2.aws.neon.tech/neondb?sslmode=require&channel_binding=require
# Integration tests point here (a throwaway Neon branch); unit tests need none.
DATABASE_URL_TEST=

# ── secrets (min lengths enforced by the loader) ────────────────────────────
APP_PEPPER=change-me-min-32-bytes-high-entropy          # HMAC-SHA256 key-hash pepper (>=32 chars)
APP_PEPPER_PREVIOUS=                                     # optional: accept keys hashed under the prior pepper during rotation (OQ8)
SUPPRESSION_SALT=change-me-min-32-bytes-high-entropy    # salt for suppression_global hashes (>=32 chars)
VERIFIER_API_KEY=                                        # MillionVerifier-class vendor key (D21)
ESP_API_KEY=                                             # Postmark-class server token (D19)

# ── outbound endpoints (host must be on the egress allowlist) ───────────────
VERIFIER_API_BASE_URL=https://api.millionverifier.com
ESP_API_BASE_URL=https://api.postmarkapp.com
ESP_FROM_EMAIL=no-reply@mail.mailmetero.com
ESP_MESSAGE_STREAM=outbound
DOH_PRIMARY_URL=https://dns.google/resolve
DOH_FALLBACK_URL=https://cloudflare-dns.com/dns-query
PUBLIC_BASE_URL=https://api.mailmetero.com               # objection-confirmation link base
# Ops escape hatch: extra outbound hosts to allowlist, comma-separated. Empty in prod.
EGRESS_EXTRA_HOSTS=

# ── kill switches & spend caps (D12) ────────────────────────────────────────
KILL_SWITCH_VERIFIER=off             # on => skip ALL paid verify, degrade to backend=none (unbilled)
KILL_SWITCH_SIGNUP=off               # on => reject POST /v2/signup
# USD caps; the loader multiplies ×100 into cents (the single spend unit) at boot.
GLOBAL_DAILY_VERIFIER_SPEND_CAP_USD=50
DEFAULT_TENANT_DAILY_SPEND_CAP_USD=5

# ── vendor data anchor (seed + blocklist-sync; NO egress) ───────────────────
# Absolute path to the vendored blocklists/nicknames. Leave empty to use the
# built-in default resolved from an absolute anchor (new URL('../../../data/vendor', import.meta.url)).
VENDOR_DIR=

# ── database pool / timeout tunables (consumed by DatabaseConfig) ────────────
POOL_MAX_WEB=8                       # web pooled-connection ceiling (default 8)
POOL_MAX_WORKER=4                    # worker/cron direct-connection ceiling (default 4)
STATEMENT_TIMEOUT_MS=8000            # per-statement timeout applied via DSN options (default 8000)
CONN_TIMEOUT_MS=5000                 # connection acquire timeout (default 5000)

# ── api tunables (ApiConfig; finder/sync budgets live in ScoringConfig, not here) ──
BODY_LIMIT_BYTES=1500000             # max request body size (default 1_500_000)
BULK_MAX_ROWS=1000                   # max rows per bulk submit (default 1000)
JOB_PENDING_RETRY_AFTER_SECONDS=2    # Retry-After for pending async jobs (default 2)
TRUST_PROXY=true                     # trust Render's proxy for client IP (default true)
OPENAPI_VERSION=1.0.0                # version string stamped into the OpenAPI doc (default 1.0.0)
